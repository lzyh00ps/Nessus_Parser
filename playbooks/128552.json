{
  "plugin_id": 128552,
  "finding_name": "FortiOS SSL VPN Web Management Interface Path Traversal (CVE-2018-13379)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/remote/login",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "FortiGate",
    "Fortinet",
    "SVPNCOOKIE",
    "SVPNNETWORK",
    "SSL-VPN"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "fortios",
      "fortigate",
      "fortinet"
    ],
    "version_patterns": [
      "FortiOS[^0-9]*([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "Fortinet FortiGate[^0-9]*([0-9]+\\.[0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "5.6.8",
    "fixed_version": "5.6.8 / 6.0.5 / 6.2.0"
  },
  "analyst_note": "CVE-2018-13379: Pre-auth path traversal in FortiOS SSL VPN web portal allows reading system files including /dev/cmdb/sslvpn_websession which contains cleartext credentials. Affects 6.0.0-6.0.4, 5.6.3-5.6.7, 5.4.6-5.4.7 (earlier may also be affected). The /remote/login path is characteristic of FortiOS SSL VPN. Set-Cookie header SVPNCOOKIE is a definitive indicator. If FortiOS SSL VPN is confirmed and version not determinable, escalate immediately \u2014 credential exposure is the impact. Fixed: 5.6.8, 6.0.5, 6.2.0.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2018-13379",
    "https://www.fortiguard.com/psirt/FG-IR-18-384",
    "https://github.com/milo2012/CVE-2018-13379",
    "https://www.exploit-db.com/exploits/47945",
    "https://attackerkb.com/topics/1RFQTj02VC/cve-2018-13379"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}