{
  "plugin_id": 48205,
  "finding_name": "Apache 2.2.x < 2.2.16 Multiple Vulnerabilities",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I http://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "apache",
      "apache httpd",
      "apache http server"
    ],
    "version_patterns": [
      "Server: Apache/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "server: apache/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "Apache/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "apache/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "http-server-header: apache/([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "2.2.16",
    "fixed_version": "2.2.16"
  },
  "analyst_note": "Apache HTTP Server version in Server response header. Fixed: 2.2.16. CVEs: CVE-2010-1452, CVE-2010-2068.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2010-1452",
