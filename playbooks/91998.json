{
  "plugin_id": 91998,
  "finding_name": "Oracle MySQL 5.7.x < 5.7.13 Multiple Vulnerabilities",
  "service": "banner",
  "port_logic": "any",
  "command_template": "nmap -Pn -sV -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "nmap -Pn --script mysql-info -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [
    "MariaDB",
    "Percona"
  ],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "mysql"
    ],
    "version_patterns": [
      "MySQL[^0-9]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "^([0-9]+\\.[0-9]+\\.[0-9]+)-MySQL",
      "mysql ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-mysql",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-log",
      "mysql-info: ([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "5.7.13",
    "fixed_version": "5.7.13"
  },
  "analyst_note": "MySQL version is visible in the initial connection banner on port 3306. Fixed: 5.7.13. CVEs: CVE-2016-2105, CVE-2016-3424, CVE-2016-3440.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2016-2105",
    "http://www.nessus.org/u?453b5f8c",
    "http://www.nessus.org/u?bac902d5",
    "https://dev.mysql.com/doc/relnotes/mysql/5.7/en/news-5-7-13.html"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}