{
  "plugin_id": 158383,
  "finding_name": "Splunk Enterprise 8.1.x / 8.2.x Log4Shell (CVE-2021-44228)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/services/server/info?output_mode=json",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 http://{host}:{port}/services/server/info?output_mode=json",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "401 Unauthorized",
    "403 Forbidden",
    "could not connect",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "401 Unauthorized": "auth_required",
    "403 Forbidden": "auth_required"
  },
  "version_rule": {
    "product_terms": [
      "splunk"
    ],
    "version_patterns": [
      "\"version\":\"([0-9]+\\.[0-9]+\\.[0-9]+)\"",
      "Splunk[/ ]([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "http-server-header: splunk[/ ]([0-9]+\\.[0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "8.1.9",
    "fixed_version": "8.1.9"
  },
  "analyst_note": "Splunk Enterprise 8.1.x before 8.1.9 and 8.2.x before 8.2.3 ship with a vulnerable version of Apache Log4j 2. The Splunk management API at port 8089 may return version info without authentication for some configurations. Fixed in Splunk 8.1.9, 8.2.3, or apply the Log4j mitigation -Dlog4j2.formatMsgNoLookups=true. Port 8089 is the Splunk management/REST API; 8000 is the web UI.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2021-44228",
    "https://www.splunk.com/en_us/product-security/announcements/svd-2021-1223.html",
    "https://github.com/fullhunt/log4j-scan",
    "https://github.com/advisories/GHSA-jfh8-c2jp-jmr7"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}