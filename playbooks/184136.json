{
  "plugin_id": 184136,
  "finding_name": "Puppet Enterprise < 2019.8.8 / 2021.x < 2021.3 PostgreSQL Vulnerability",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/puppet/v3/environments",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "401 unauthorized"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "401 unauthorized": "auth_required"
  },
  "version_rule": {
    "product_terms": [
      "puppet"
    ],
    "version_patterns": [
      "Puppet/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "puppet/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "X-Puppet-Version: ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "x-puppet-version: ([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "2019.8.8",
    "fixed_version": "2019.8.8"
  },
  "analyst_note": "Puppet version in X-Puppet-Version response header or API response. Fixed: 2019.8.8. CVEs: CVE-2021-3677.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2021-3677",
    "http://www.nessus.org/u?2d86f6c0",
    "https://www.postgresql.org/support/security/CVE-2021-3677/"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}