{
  "plugin_id": 94761,
  "finding_name": "SSL Root Certification Authority Certificate Information",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "sslscan --no-colour --show-certificate {sslscan_starttls_args} --sni-name={host} {host}:{port}",
  "timeout_seconds": 45,
  "allowed_ports": [
    21, 25, 110, 143, 389, 443, 465, 563, 587, 636, 853, 989, 990, 992, 993, 994, 995,
    1311, 2083, 2087, 2096, 2376, 3269, 3389, 5061, 5222, 5269, 5349, 5432, 5986, 6443,
    6514, 6697, 8172, 8443, 8531, 8883, 9200, 9443, 10443
  ],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "validated_if": [
    "issuer:",
    "subject:"
  ],
  "validated_if_absent": [],
  "not_validated_if": [],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "connection timed out",
    "failed to resolve"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "connection timed out": "port_filtered",
    "failed to resolve": "host_down"
  },
  "references": [
    "https://github.com/rbsec/sslscan"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}
