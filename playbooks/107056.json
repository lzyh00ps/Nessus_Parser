{
  "plugin_id": 107056,
  "finding_name": "Hikvision IP Camera / NVR Authentication Bypass (CVE-2017-7921)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I http://{host}:{port}/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "Hikvision",
    "DNVRS-Webs",
    "App-webs",
    "DVRDVS-Webs"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "hikvision",
      "dnvrs",
      "dvrdvs"
    ],
    "version_patterns": [
      "Hikvision[^0-9]*([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "App-webs/([0-9]+\\.[0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "5.5.0",
    "fixed_version": "5.5.0"
  },
  "analyst_note": "CVE-2017-7921: Authentication bypass in Hikvision IP cameras and NVRs allows unauthenticated access to full configuration, live video, and administrator credentials via simple URL manipulation. The DNVRS-Webs, App-webs, or DVRDVS-Webs Server header is a definitive indicator of Hikvision firmware. These devices are commonly found internet-exposed and are primary targets for botnets (Mirai variants). Millions of devices worldwide remain vulnerable. If Hikvision indicators are present, treat as validated unless firmware version confirms patch.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2017-7921",
    "https://ics-cert.us-cert.gov/advisories/ICSA-17-124-01",
    "https://github.com/bp2008/HikPasswordHelper",
    "https://www.exploit-db.com/exploits/44040",
    "https://seclists.org/fulldisclosure/2017/Sep/23"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}