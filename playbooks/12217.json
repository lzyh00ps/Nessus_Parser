{
  "plugin_id": 12217,
  "finding_name": "DNS Server Cache Snooping Remote Information Disclosure",
  "service": "dns",
  "port_logic": "use_scan_port",
  "command_template": "sh -c 'out=$(dig @{host} example.com A +norecurse +time=5 +tries=1 2>&1); printf \"%s\\n\" \"$out\"; printf \"%s\\n\" \"$out\" | grep -qi \"status: noerror\" && printf \"%s\\n\" \"$out\" | grep -Eqi \"ANSWER: [1-9]\" && printf \"%s\\n\" \"$out\" | grep -qi \"example.com\\.\" && echo CACHE_SNOOPING_ENABLED || echo CACHE_SNOOPING_DISABLED'",
  "timeout_seconds": 15,
  "allowed_ports": [53],
  "blocked_ports": [],
  "starttls_protocol_map": {},
  "fallback_commands": [],
  "version_rule": {},
  "validated_if": [
    "cache_snooping_enabled"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "cache_snooping_disabled"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection timed out",
    "communications error",
    "no servers could be reached",
    "failed to resolve"
  ],
  "failure_reason_map": {
    "connection timed out": "port_filtered",
    "communications error": "inconclusive",
    "no servers could be reached": "host_down",
    "failed to resolve": "host_down"
  },
  "references": [
    "https://bind9.readthedocs.io/",
    "https://manpages.debian.org/dig"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}
