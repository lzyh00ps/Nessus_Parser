      "php/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "http-server-header: php/([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "5.3.0",
    "fixed_version": "5.3.0"
  },
  "analyst_note": "PHP version exposed via X-Powered-By HTTP response header (if expose_php=On in php.ini). Fixed: 5.3.0.",
