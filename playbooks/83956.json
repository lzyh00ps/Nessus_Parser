      "Jenkins/([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)",
      "jenkins/([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)"
    ],
    "affected_lt": "1.565.3",
    "fixed_version": "1.565.3"
  },
  "analyst_note": "Jenkins exposes its version in the X-Jenkins HTTP response header. Fixed: 1.565.3. CVEs: CVE-2014-9634, CVE-2014-9635.",
  "references": [
