{
  "plugin_id": 88698,
  "finding_name": "MySQL Enterprise Server 5.6.x < 5.6.29 / 5.7.x < 5.7.11 OpenSSL Multiple Vulnerabilities",
  "service": "banner",
  "port_logic": "any",
  "command_template": "nmap -Pn -sV -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "nmap -Pn --script mysql-info -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [
    "MariaDB",
    "Percona"
  ],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "mysql"
    ],
    "version_patterns": [
      "MySQL[^0-9]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "^([0-9]+\\.[0-9]+\\.[0-9]+)-MySQL",
      "mysql ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-mysql",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-log",
      "mysql-info: ([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "5.6.29",
    "fixed_version": "5.6.29"
  },
  "analyst_note": "MySQL version is visible in the initial connection banner on port 3306. Fixed: 5.6.29. CVEs: CVE-2015-3194, CVE-2015-3195.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2015-3194",
    "http://dev.mysql.com/doc/relnotes/mysql/5.6/en/news-5-6-29.html",
    "https://dev.mysql.com/doc/relnotes/mysql/5.7/en/news-5-7-11.html"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}