{
  "plugin_id": 167905,
  "finding_name": "MariaDB 10.0.0 < 10.0.1 Multiple Vulnerabilities",
  "service": "banner",
  "port_logic": "any",
  "command_template": "nmap -Pn -sV -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "nmap -Pn --script mysql-info -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "mariadb"
    ],
    "version_patterns": [
      "MariaDB[^0-9]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "([0-9]+\\.[0-9]+\\.[0-9]+-MariaDB)",
      "mariadb ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-mariadb",
      "mysql-info: ([0-9]+\\.[0-9]+\\.[0-9]+)-mariadb"
    ],
    "affected_lt": "10.0.1",
    "fixed_version": "10.0.1"
  },
  "analyst_note": "MariaDB version is visible in the connection banner on port 3306. Fixed: 10.0.1. CVEs: CVE-2012-0572, CVE-2012-0574, CVE-2012-0578.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2012-0572",
    "http://www.nessus.org/u?2f4602d1"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}