{
  "plugin_id": 186836,
  "finding_name": "Jenkins plugins Multiple Vulnerabilities (2023-12-13 Advisory)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I http://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "jenkins"
    ],
    "version_patterns": [
      "X-Jenkins: ([0-9]+\\.[0-9.]+)",
      "Hudson-Version: ([0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "11.13.0",
    "fixed_version": "11.13.0 (Git plugin) / varies by plugin"
  },
  "analyst_note": "Jenkins 2023-12-13 advisory covers 17 CVEs across multiple plugins (Git, Pipeline, GitHub, etc.) including path traversal, CSRF, XXE, and secret exposure vulnerabilities. The X-Jenkins response header reveals the Jenkins core version. Plugin versions are only verifiable via authenticated API (/pluginManager/api/json). If Jenkins is detected and version < 11.13.0 (Git plugin) or recent advisory date, treat as inconclusive pending plugin inventory. Escalate for plugin update audit.",
  "references": [
    "https://www.jenkins.io/security/advisory/2023-12-13/",
    "https://nvd.nist.gov/vuln/detail/CVE-2023-50764"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}