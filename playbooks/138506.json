{
  "plugin_id": 138506,
  "finding_name": "SAP NetWeaver AS Java RECON Unauthenticated Admin Access (CVE-2020-6287)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/webdynpro/resources/sap.com/tc~wd~tools~masteradmin/WDDeployableObjectsTableApp",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I http://{host}:{port}/webdynpro/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "200 OK"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [
    "401 Unauthorized",
    "403 Forbidden"
  ],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "404 Not Found",
    "500 Internal"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "404 Not Found": "endpoint_not_found",
    "500 Internal": "server_error"
  },
  "version_rule": {},
  "analyst_note": "CVE-2020-6287 (RECON - Remotely Exploitable Code On NetWeaver): CVSS 10.0 unauthenticated admin takeover of SAP NetWeaver AS Java. If the /webdynpro/resources/ endpoint returns 200 without authentication, the system is likely vulnerable. SAP NetWeaver AS Java typically runs on port 50000 (HTTP) or 50001 (HTTPS). Affected versions: SAP NetWeaver AS Java 7.30, 7.31, 7.40, 7.50. Fixed in SAP Security Note 2934135. If the endpoint returns 200 OK, escalate immediately \u2014 this allows unauthenticated OS command execution via the User Management Engine.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2020-6287",
    "https://www.onapsis.com/recon-sap-cyber-security-vulnerability",
    "https://github.com/chipik/SAP_RECON",
    "https://packetstormsecurity.com/files/158704/"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}