{
  "plugin_id": 139386,
  "finding_name": "Ansible Tower 3.x.x < 3.7.2 / 3.8.0 Data Exposure",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/api/v2/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "401 unauthorized"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "401 unauthorized": "auth_required"
  },
  "version_rule": {
    "product_terms": [
      "ansible",
      "ansible tower",
      "awx"
    ],
    "version_patterns": [
      "ansible[/ ]([0-9]+\\.[0-9]+\\.[0-9]+)",
      "Ansible[/ ]([0-9]+\\.[0-9]+\\.[0-9]+)",
      "tower[/ ]([0-9]+\\.[0-9]+\\.[0-9]+)",
      "AWX[/ ]([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "3.7.2",
    "fixed_version": "3.7.2"
  },
  "analyst_note": "Ansible Tower/AWX version via /api/v2/ endpoint. Fixed: 3.7.2. CVEs: CVE-2020-14337.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2020-14337",
    "https://bugzilla.redhat.com/show_bug.cgi?id=CVE-2020-14337",
    "https://access.redhat.com/security/cve/cve-2020-14337"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}