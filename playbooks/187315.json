{
  "plugin_id": 187315,
  "finding_name": "SSH Terrapin Prefix Truncation Weakness (CVE-2023-48795)",
  "service": "banner",
  "port_logic": "use_scan_port",
  "command_template": "sh -c 'out=$(nmap -Pn --script ssh2-enum-algos -p {port} {host} 2>&1); printf \"%s\\n\" \"$out\"; lower=$(printf \"%s\\n\" \"$out\" | tr \"[:upper:]\" \"[:lower:]\" ); printf \"%s\\n\" \"$lower\" | grep -Eqi \"(chacha20-poly1305@openssh.com|aes128-cbc|aes192-cbc|aes256-cbc|3des-cbc|blowfish-cbc|cast128-cbc)\" && printf \"%s\\n\" \"$lower\" | grep -Eqi \"etm@openssh.com\" && echo TERRAPIN_RISK || echo TERRAPIN_NOT_CONFIRMED'",
  "timeout_seconds": 30,
  "allowed_ports": [
    22
  ],
  "blocked_ports": [],
  "starttls_protocol_map": {},
  "fallback_commands": [],
  "version_rule": {},
  "validated_if": [
    "terrapin_risk"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "terrapin_not_confirmed"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "operation not permitted"
  ],
  "failure_reason_map": {
    "failed to resolve": "host_down",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "operation not permitted": "inconclusive"
  },
  "references": [
    "https://nmap.org/nsedoc/scripts/ssh2-enum-algos.html",
    "https://terrapin-attack.com/"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16",
  "fallback_commands_json": [
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ]
}
