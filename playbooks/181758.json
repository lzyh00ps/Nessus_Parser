{
  "plugin_id": 181758,
  "finding_name": "Nagios XI < 5.11.2 Multiple Vulnerabilities",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/nagiosxi/login.php",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 http://{host}:{port}/nagiosxi/login.php",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "Nagios",
    "nagiosxi",
    "Nagios XI"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "404 Not Found"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "404 Not Found": "endpoint_not_found"
  },
  "version_rule": {
    "product_terms": [
      "nagios xi",
      "nagiosxi"
    ],
    "version_patterns": [
      "Nagios XI ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "nagiosxi/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "version[^0-9]*([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "5.11.2",
    "fixed_version": "5.11.2"
  },
  "analyst_note": "Nagios XI < 5.11.2 has multiple vulnerabilities including authenticated RCE via command injection in check result processing. The /nagiosxi/login.php path is characteristic of Nagios XI. Version may appear in page title or footer HTML. If Nagios XI is detected, escalate for patch \u2014 it is a frequent target due to privileged network access. Nagios XI should not be internet-facing. Fixed: 5.11.2.",
  "references": [
    "https://www.nagios.com/downloads/nagios-xi/change-log/",
    "https://nvd.nist.gov/vuln/detail/CVE-2023-40931",
    "https://github.com/X1r0z/Nagios-RCE"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}