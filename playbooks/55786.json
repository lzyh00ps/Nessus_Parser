{
  "plugin_id": 55786,
  "finding_name": "Oracle Database Unsupported Version Detection",
  "service": "banner",
  "port_logic": "use_scan_port",
  "command_template": "nmap -Pn --script oracle-tns-version -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {},
  "fallback_commands": [
    "nmap -Pn -sV --version-intensity 7 -p {port} {host}"
  ],
  "version_rule": {
    "product_terms": [
      "oracle",
      "tnslsnr",
      "installed version"
    ],
    "version_patterns": [
      "installed version\\s*:\\s*([0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9.]+)",
      "tnslsnr[^\\n]*?version\\s+([0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9.]+)",
      "tnslsnr[^\\n]*?([0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+)",
      "oracle[^\\n]*?([0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "19"
  },
  "validated_if": [],
  "validated_if_absent": [],
  "not_validated_if": [],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "filtered",
    "closed",
    "host seems down",
    "failed to resolve",
    "timed out",
    "0 hosts up",
    "no route to host"
  ],
  "failure_reason_map": {
    "filtered": "port_filtered",
    "closed": "port_closed",
    "host seems down": "host_down",
    "failed to resolve": "host_down",
    "timed out": "port_filtered",
    "0 hosts up": "host_down",
    "no route to host": "host_down"
  },
  "references": [],
  "reviewed_by": "analyst",
  "last_verified": "2026-04-06"
}