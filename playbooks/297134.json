{
  "plugin_id": 297134,
  "finding_name": "Zimbra Collaboration Server 10.0.x < 10.0.18 / 10.1.x < 10.1.13 Local Privilege Escalation / RCE",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/zimbra/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I http://{host}:{port}/zimbra/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "Zimbra",
    "zimbra"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "404 Not Found"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "404 Not Found": "endpoint_not_found"
  },
  "version_rule": {
    "product_terms": [
      "zimbra"
    ],
    "version_patterns": [
      "Zimbra[^0-9]*([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "X-Zimbra-Version: ([0-9]+\\.[0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "10.0.18",
    "fixed_version": "10.0.18 / 10.1.13"
  },
  "analyst_note": "Zimbra Collaboration Server vulnerabilities including potential RCE and privilege escalation. Zimbra is frequently targeted by threat actors (ProxyShell-like chains, CVE-2022-41352). The /zimbra/ path is definitive. Port 7071 is the Zimbra admin console. X-Zimbra-Version header may expose version. Fixed: 10.0.18, 10.1.13.",
  "references": [
    "https://wiki.zimbra.com/wiki/Zimbra_Security_Advisories",
    "https://nvd.nist.gov/vuln/detail/CVE-2024-45519"
  ],
