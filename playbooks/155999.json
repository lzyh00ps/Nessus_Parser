{
  "plugin_id": 155999,
  "finding_name": "Apache Log4j 2.x < 2.15.0 Remote Code Execution (CVE-2021-44228 / Log4Shell)",
  "service": "https",
  "port_logic": "any",
  "command_template": "nmap -Pn -sV --version-light -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 15 -I https://{host}:{port}/",
    "curl -k -s -m 15 -I http://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {},
  "analyst_note": "Log4j is an embedded Java library — direct remote version enumeration is not possible via banner grabbing. If the target service is reachable, treat as inconclusive and perform manual JNDI callback testing using the PoC tools referenced below. Key indicators: Java-based apps (Elasticsearch, Solr, Logstash, VMware vCenter, Apache Solr, Minecraft, etc.). Patch: upgrade to Log4j 2.15.0+ or 2.17.1+ (preferred).",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2021-44228",
    "https://logging.apache.org/log4j/2.x/security.html",
    "https://github.com/fullhunt/log4j-scan",
    "https://github.com/advisories/GHSA-jfh8-c2jp-jmr7",
    "https://www.lunasec.io/docs/blog/log4j-zero-day/",
    "https://github.com/christophetd/log4shell-vulnerable-app"
  ],
  "reviewed_by": "analyst",
