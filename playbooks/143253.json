{
  "plugin_id": 143253,
  "finding_name": "phpMyAdmin 4.7.x < 4.7.7 XSRF/CSRF Vulnerability (PMASA-2017-9)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/phpmyadmin/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 http://{host}:{port}/phpmyadmin/",
    "curl -k -s -m 20 https://{host}:{port}/pma/",
    "curl -k -s -m 20 https://{host}:{port}/phpMyAdmin/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "404 Not Found"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "404 Not Found": "endpoint_not_found"
  },
  "version_rule": {
    "product_terms": [
      "phpmyadmin"
    ],
    "version_patterns": [
      "phpMyAdmin ([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "PMA_VERSION[^>]*>([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "version[^0-9]*([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "4.7.7",
    "fixed_version": "4.7.7"
  },
  "analyst_note": "phpMyAdmin 4.7.x < 4.7.7 CSRF vulnerability (PMASA-2017-9) allowing attackers to perform database operations via forged requests. phpMyAdmin is commonly installed at /phpmyadmin/, /pma/, or /phpMyAdmin/. The version is visible in the page title or HTML. phpMyAdmin should never be internet-accessible. If accessible, also note the direct database access risk as a separate finding. Fixed: 4.7.7.",
  "references": [
    "https://www.phpmyadmin.net/security/PMASA-2017-9/",
    "https://nvd.nist.gov/vuln/detail/CVE-2017-18264"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}