{
  "plugin_id": 157848,
  "finding_name": "SAP Internet Communication Manager Advanced Desync (ICMAD) Remote Code Execution (CVE-2022-22536)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I http://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "SAP",
    "ICM",
    "NetWeaver"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "sap",
      "icm",
      "netweaver"
    ],
    "version_patterns": [
      "SAP NetWeaver[^0-9]*([0-9]+\\.[0-9]+[^\\s,]*)",
      "SAP[^/]*/([0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "7.22",
    "fixed_version": "7.22 (SAP Note 3123396)"
  },
  "analyst_note": "CVE-2022-22536 (ICMAD): HTTP request smuggling / desync vulnerability in SAP ICM. CVSS 10.0. Affects SAP NetWeaver AS ABAP, SAP NetWeaver AS Java, SAP Content Server. The Server response header may contain 'SAP' or 'ICM'. SAP typically runs on ports 443 (HTTPS), 8443, 8000, or 44300. If SAP headers are detected, treat as validated pending patch confirmation. Apply SAP Security Notes 3123396, 3123427, 3140940.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2022-22536",
