{
  "plugin_id": 163332,
  "finding_name": "Oracle MySQL Server < 8.0.30 Multiple Vulnerabilities (July 2022 CPU)",
  "service": "banner",
  "port_logic": "any",
  "command_template": "nmap -Pn -sV -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "nmap -Pn --script mysql-info -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [
    "MariaDB",
    "Percona"
  ],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "mysql"
    ],
    "version_patterns": [
      "MySQL[^0-9]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "^([0-9]+\\.[0-9]+\\.[0-9]+)-MySQL",
      "mysql ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-mysql",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-log"
    ],
    "affected_lt": "8.0.30",
    "fixed_version": "8.0.30"
  },
  "analyst_note": "Oracle MySQL July 2022 CPU fixes 26 vulnerabilities across MySQL 5.7 and 8.0. MySQL exposes its version in the initial handshake banner on port 3306 \u2014 nmap -sV reliably extracts this. Note: MariaDB also uses port 3306 and produces similar banners; check for 'MariaDB' in the version string to distinguish. MySQL should not be internet-facing without authentication \u2014 if port 3306 is directly exposed, document as a network segmentation finding as well. Fixed: 8.0.30.",
  "references": [
    "https://www.oracle.com/security-alerts/cpujul2022.html",
    "https://nvd.nist.gov/vuln/detail/CVE-2022-21540"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}