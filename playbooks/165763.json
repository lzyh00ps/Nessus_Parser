{
  "plugin_id": 165763,
  "finding_name": "FortiOS / FortiProxy Authentication Bypass (CVE-2022-40684)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/login",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 http://{host}:{port}/login",
    "curl -k -s -m 20 https://{host}:{port}/remote/login",
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "FortiGate",
    "Fortinet",
    "FortiProxy",
    "APSCOOKIE",
    "fortinet"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "fortigate",
      "fortios",
      "fortiproxy"
    ],
    "version_patterns": [
      "FortiOS[/ v]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "fortios[/ v]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "FortiGate[/ v]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "fortigate[/ v]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "v([0-9]+\\.[0-9]+\\.[0-9]+),build[0-9]+",
      "firmware version.*?v?([0-9]+\\.[0-9]+\\.[0-9]+)",
      "http-server-header: fortiweb[/ ]([0-9]+\\.[0-9]+\\.[0-9]+)",
      "fortigate-([0-9]+\\.[0-9]+\\.[0-9]+)",
      "FortiOS[^0-9]*([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "Fortinet[^0-9]*([0-9]+\\.[0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "7.0.5",
    "fixed_version": "7.0.5 / 7.2.1"
  },
  "analyst_note": "CVE-2022-40684: Authentication bypass via alternative HTTP path in FortiOS 7.0.0-7.0.4 and 7.2.0, FortiProxy 7.0.0-7.0.6 and 7.2.0. Exploited as zero-day by threat actors. CVSS 9.8. The API endpoint /api/v2/cmdb/system/admin is accessible if the authentication bypass applies. Fortinet headers (Set-Cookie: APSCOOKIE, Server: xxxxxxxx-FortiGate) are strong indicators. If Fortinet detected, escalate for manual patch verification. Fixed: FortiOS 7.0.5, 7.2.1; FortiProxy 7.0.7, 7.2.1.",
  "references": [
