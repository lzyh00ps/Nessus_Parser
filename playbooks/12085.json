{
  "plugin_id": 12085,
  "finding_name": "Apache Tomcat Default Files",
  "service": "banner",
  "port_logic": "use_scan_port",
  "command_template": "curl -k -s --max-time 20 http://{host}:{port}/nessus_missing_page_404",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 http://{host}:{port}/",
    "curl -k -s -m 20 https://{host}:{port}/nessus_version_check",
    "curl -k -s -m 20 http://{host}:{port}/nessus_version_check",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "apache tomcat",
    "apache-tomcat",
    "apache coyote",
    "the requested resource is not available",
    "http status 404 - /nessus_missing_page_404",
    "apache tomcat/"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "could not connect",
    "host seems down",
    "failed to resolve"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "could not connect": "port_closed",
    "host seems down": "host_down",
    "failed to resolve": "host_down"
  },
  "version_rule": {
    "product_terms": [
      "tomcat",
      "apache tomcat"
    ],
    "version_patterns": [
      "Apache Tomcat/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "apache tomcat/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "Tomcat/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "tomcat/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "http-server-header: apache-coyote",
      "http-title: apache tomcat/([0-9]+\\.[0-9]+\\.[0-9]+)",
      "http-title: apache tomcat - error report",
      "http-server-header: apache-coyote/([0-9]+\\.[0-9]+)"
    ]
  },
  "analyst_note": "Apache Tomcat version appears in default error/welcome pages and optionally the Server header.",
  "references": [
    "http://www.nessus.org/u?4cb3b4dd",
    "https://www.owasp.org/index.php/Securing_tomcat"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16",
  "fallback_commands": [
    "curl -k -s --max-time 20 https://{host}:{port}/nessus_missing_page_404",
    "curl -k -s --max-time 20 http://{host}:{port}/"
  ]
}