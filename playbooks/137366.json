{
  "plugin_id": 137366,
  "finding_name": "Joomla! 2.5.x < 3.9.19 Multiple Vulnerabilities",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/administrator/manifests/files/joomla.xml",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 http://{host}:{port}/administrator/manifests/files/joomla.xml",
    "curl -k -s -m 20 https://{host}:{port}/administrator/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "404 Not Found",
    "403 Forbidden"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "404 Not Found": "endpoint_not_found",
    "403 Forbidden": "auth_required"
  },
  "version_rule": {
    "product_terms": [
      "joomla"
    ],
    "version_patterns": [
      "<version>([0-9]+\\.[0-9]+\\.[0-9]+)</version>",
      "Joomla! ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "http-generator: joomla[^0-9]*([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "3.9.19",
    "fixed_version": "3.9.19"
  },
  "analyst_note": "Joomla! 2.5-3.9.18 multiple vulnerabilities. The /administrator/manifests/files/joomla.xml file (if accessible) contains the exact Joomla version in XML format (<version>3.9.18</version>). This is a highly reliable version detection method when accessible. Fixed: 3.9.19.",
  "references": [
    "https://www.joomla.org/announcements/release-news/5810-joomla-3-9-19.html",
    "https://developer.joomla.org/security-centre.html"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}