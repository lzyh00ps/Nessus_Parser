{
  "plugin_id": 121008,
  "finding_name": "SSL / TLS Certificate Known Hard Coded Private Keys",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "sslscan --no-colour --show-certificate {sslscan_starttls_args} {host}:{port}",
  "timeout_seconds": 30,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {},
  "fallback_commands": [
    "openssl s_client -connect {host}:{port} {openssl_tls_args} -showcerts </dev/null 2>&1"
  ],
  "version_rule": {},
  "validated_if": [
    "subject:",
    "issuer:",
    "certificate:",
    "axentraserver default",
    "default certificate",
    "self-signed certificate",
    "self signed certificate"
  ],
  "validated_if_absent": [],
  "not_validated_if": [],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "could not resolve",
    "host seems down",
    "failed to resolve",
    "no route to host"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "host seems down": "host_down",
    "could not resolve": "host_down",
    "failed to resolve": "host_down",
    "no route to host": "host_down"
  },
  "references": [],
  "reviewed_by": null,
  "last_verified": null
}