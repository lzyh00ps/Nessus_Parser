{
  "plugin_id": 106484,
  "finding_name": "Cisco ASA Software IKEv1/IKEv2 Remote Code Execution (CVE-2018-0101)",
  "service": "https",
  "port_logic": "any",
  "command_template": "nmap -Pn -sV --version-light -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I https://{host}:{port}/+CSCOE+/logon.html",
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [
    "Cisco Adaptive Security Appliance"
  ],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "ssl handshake",
    "network is unreachable"
