{
  "plugin_id": 176861,
  "finding_name": "ManageEngine Multiple Products SAML Authentication Bypass / Remote Code Execution (CVE-2022-47966)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I http://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "ManageEngine",
    "ZOHO",
    "Zoho Corporation",
    "AdventNet"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "manageengine",
      "zoho",
      "servicedesk",
      "opmanager",
      "adaudit"
    ],
    "version_patterns": [
      "ManageEngine[^0-9]*([0-9]+(?:\\.[0-9]+)*)",
      "Build[^0-9]*([0-9]+)"
    ],
    "affected_lt": "14000",
    "fixed_version": "Build 14000 (varies by product)"
  },
  "analyst_note": "CVE-2022-47966: Pre-auth RCE via SAML XML signature verification bypass using Apache Santuario library. Affects 24 ManageEngine products if SAML SSO was previously enabled. Products include: ServiceDesk Plus, OpManager, ADSelfService Plus, SupportCenter Plus, Password Manager Pro, and more. Response headers typically contain 'Server: ManageEngine' or 'X-ME-Version'. If ManageEngine is detected and SAML was configured, treat as critical. Check build number via the product login page. Fixed: various build numbers around 14000.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2022-47966",
    "https://www.manageengine.com/security/advisory/CVE/cve-2022-47966.html",
    "https://github.com/horizon3ai/CVE-2022-47966",
    "https://attackerkb.com/topics/gvs8Gam0eL/cve-2022-47966"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}