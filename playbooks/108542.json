{
  "plugin_id": 108542,
  "finding_name": "Webmin < 1.370 Unspecified Command Execution Vulnerability",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "Webmin",
    "MiniServ"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "webmin",
      "miniserv"
    ],
    "version_patterns": [
      "MiniServ/([0-9]+\\.[0-9.]+)",
      "Webmin/([0-9]+\\.[0-9.]+)",
      "server: miniserv/([0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "1.370",
    "fixed_version": "1.370"
  },
  "analyst_note": "Webmin < 1.370 command execution vulnerability. MiniServ/X.Y in Server header provides reliable version detection. Fixed: 1.370.",
  "references": [
    "https://www.webmin.com/security.html",
    "https://nvd.nist.gov/vuln/detail/CVE-2009-4876"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}