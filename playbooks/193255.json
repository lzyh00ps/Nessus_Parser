{
  "plugin_id": 193255,
  "finding_name": "Palo Alto PAN-OS GlobalProtect OS Command Injection (CVE-2024-3400)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/global-protect/login.esp",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "PAN-OS",
    "Palo Alto",
    "GlobalProtect",
    "PHPSESSID",
    "pan_"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "pan-os",
      "palo alto",
      "globalprotect"
    ],
    "version_patterns": [
      "PAN-OS[^0-9]*([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "pan_version[^>]*>([0-9]+\\.[0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "11.1.2-h3",
    "fixed_version": "10.2.9-h1 / 11.0.4-h1 / 11.1.2-h3"
  },
  "analyst_note": "CVE-2024-3400: CVSS 10.0 OS command injection in PAN-OS GlobalProtect Gateway when both GlobalProtect gateway and device telemetry are enabled. Exploited as zero-day by UTA0218. The /global-protect/login.esp path is characteristic of GlobalProtect. PAN-OS may include 'X-Pan-OS-Version' in HTTP headers on some configurations. If GlobalProtect is confirmed, apply mitigations immediately: disable telemetry (System > Configuration > Telemetry > uncheck all) or apply Threat Prevention signatures 95187/95189. Fixed: 10.2.9-h1, 11.0.4-h1, 11.1.2-h3.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2024-3400",
    "https://security.paloaltonetworks.com/CVE-2024-3400",
    "https://unit42.paloaltonetworks.com/cve-2024-3400/",
    "https://github.com/ihebski/CVE-2024-3400",
    "https://attackerkb.com/topics/SSTk2wVBmH/cve-2024-3400"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}