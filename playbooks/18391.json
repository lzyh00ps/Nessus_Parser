{
  "plugin_id": 18391,
  "finding_name": "SMTP Server Non-standard Port Detection",
  "service": "banner",
  "port_logic": "use_scan_port",
  "command_template": "sh -c 'out=$(nmap -Pn -sV --version-light -p {port} {host} 2>&1); printf \"%s\\n\" \"$out\"; printf \"%s\\n\" \"$out\" | tr \"[:upper:]\" \"[:lower:]\" | grep -Eqi \"smtp|esmtp|exim|postfix\" && echo NONSTANDARD_SMTP_PRESENT || echo NONSTANDARD_SMTP_ABSENT'",
  "timeout_seconds": 30,
  "allowed_ports": [],
  "blocked_ports": [
    25,
    465,
    587
  ],
  "starttls_protocol_map": {},
  "fallback_commands": [],
  "version_rule": {},
  "validated_if": [
    "nonstandard_smtp_present"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "nonstandard_smtp_absent"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "operation not permitted"
  ],
  "failure_reason_map": {
    "failed to resolve": "host_down",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "operation not permitted": "inconclusive"
  },
  "references": [
    "https://nmap.org/book/man-version-detection.html"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16",
  "fallback_commands_json": [
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ]
}
