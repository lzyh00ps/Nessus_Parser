{
  "plugin_id": 42880,
  "finding_name": "TLS Renegotiation Handshakes MiTM Plaintext Data Injection",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "openssl s_client -connect {host}:{port} {openssl_tls_args} </dev/null",
  "timeout_seconds": 30,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "587": "smtp",
    "5432": "postgres"
  },
  "fallback_commands": [],
  "version_rule": {},
  "validated_if": [
    "secure renegotiation is not supported",
    "renegotiation is not supported"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "secure renegotiation is supported"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "bio_lookup_ex:system lib",
    "temporary failure in name resolution"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "bio_lookup_ex:system lib": "host_down",
    "temporary failure in name resolution": "host_down"
  },
  "references": [
    "https://docs.openssl.org/3.6/man1/openssl-s_client/",
    "https://www.tenable.com/plugins/nessus/42880"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-04-05"
}