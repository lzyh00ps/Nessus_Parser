      "tomcat"
    ],
    "version_patterns": [
      "apache tomcat/(9\\.0\\.\\d+)",
      "tomcat.{0,40}(9\\.0\\.\\d+)"
    ],
    "fixed_version": "9.0.110"
  },
  "validated_if": [],
  "validated_if_absent": [],
  "not_validated_if": [],
