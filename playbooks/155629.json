      "jenkins/([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)"
    ],
    "affected_lt": "2.249.31.0.3",
    "fixed_version": "2.249.31.0.3"
  },
  "analyst_note": "Jenkins exposes its version in the X-Jenkins HTTP response header. Fixed: 2.249.31.0.3.",
