{
  "plugin_id": 11980,
  "finding_name": "Compaq/HP WBEM Server SSI Denial of Service",
  "service": "banner",
  "command_template": "sh -c 'out=$(nmap -Pn -sV --version-light -p {port} {host} 2>&1); printf \"%s\\n\" \"$out\"; curl -k -s -I --max-time 10 http://{host}:{port}/ 2>&1'",
  "timeout_seconds": 20,
  "allowed_ports": [
    2301,
    2381
  ],
  "blocked_ports": [],
  "starttls_protocol_map": {},
  "fallback_commands": [],
  "version_rule": {},
  "validated_if": [
    "compaq wbem",
    "hp wbem",
    "compaq web-based enterprise management",
    "server: compaq",
    "hp web-based enterprise management"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "server: apache/2.4",
    "server: apache/2.2",
    "server: nginx/1.",
    "server: openresty/",
    "server: microsoft-iis/7",
    "server: microsoft-iis/8",
    "server: microsoft-iis/10",
    "server: lighttpd/1.",
    "server: tomcat/",
    "server: jetty/"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "operation not permitted"
  ],
  "failure_reason_map": {
    "failed to resolve": "host_down",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "operation not permitted": "inconclusive"
  },
  "references": [
    "https://www.hp.com/"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16",
  "fallback_commands_json": [
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ]
}
