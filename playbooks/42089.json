{
  "plugin_id": 42089,
  "finding_name": "XMPP Service STARTTLS Command Support",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "openssl s_client -connect {host}:{port} {openssl_tls_args} -brief </dev/null",
  "timeout_seconds": 30,
  "allowed_ports": [5222, 5269],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "5222": "xmpp",
    "5269": "xmpp-server"
  },
  "validated_if": [
    "connection established",
    "protocol version:"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "didn't find starttls",
    "unsupported protocol",
    "handshake failure"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "temporary failure in name resolution",
    "bio_lookup_ex:system lib"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "temporary failure in name resolution": "host_down",
    "bio_lookup_ex:system lib": "host_down"
  },
  "references": [
    "https://docs.openssl.org/3.6/man1/openssl-s_client/"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}
