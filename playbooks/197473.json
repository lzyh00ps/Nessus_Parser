{
  "plugin_id": 197473,
  "finding_name": "GitLab 11.2 < 13.2.10 / 13.3.x < 13.3.7 / 13.4.x < 13.4.2 Multiple Vulnerabilities",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/api/v4/version",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 http://{host}:{port}/api/v4/version",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "401 Unauthorized",
    "403 Forbidden"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "401 Unauthorized": "auth_required",
    "403 Forbidden": "auth_required"
  },
  "version_rule": {
    "product_terms": [
      "gitlab"
    ],
    "version_patterns": [
      "\"version\":\"([0-9]+\\.[0-9]+\\.[0-9]+)\"",
      "GitLab/([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "13.2.10",
    "fixed_version": "13.2.10 / 13.3.7 / 13.4.2"
  },
  "analyst_note": "GitLab CE/EE 11.2-13.4 multiple vulnerabilities (CVE-2020-13379 SSRF, CVE-2020-13121 and others). Fixed: 13.2.10, 13.3.7, 13.4.2.",
  "references": [
    "https://about.gitlab.com/releases/2020/09/02/security-release-13-3-7-released/",
    "https://nvd.nist.gov/vuln/detail/CVE-2020-13379"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}