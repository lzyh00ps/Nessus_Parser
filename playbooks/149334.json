{
  "plugin_id": 149334,
  "finding_name": "SSH Password Authentication Accepted",
  "service": "banner",
  "port_logic": "use_scan_port",
  "command_template": "sh -c 'out=$(nmap -Pn --script ssh-auth-methods -p {port} {host} 2>&1); echo \"$out\"; echo \"$out\" | grep -qi \"password\" && echo SSH_PASSWORD_AUTH_ENABLED || echo SSH_PASSWORD_AUTH_DISABLED'",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "ssh_password_auth_enabled"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [
    "ssh_password_auth_disabled"
  ],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "0 hosts up",
    "host seems down",
    "failed to resolve",
    "timed out",
    "connection refused",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "failed to resolve": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_down",
    "network is unreachable": "host_down"
  },
  "version_rule": {},
  "analyst_note": "Plugin 149334 fires when SSH server accepts password authentication. nmap --script ssh-auth-methods lists accepted methods. If 'password' appears in supported methods \u2192 finding is valid.",
  "references": [
    "https://nmap.org/nsedoc/scripts/ssh-auth-methods.html",
    "https://www.tenable.com/plugins/nessus/149334"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16",
  "allowed_ports": [
    22
  ],
  "blocked_ports": [],
  "starttls_protocol_map": {},
  "fallback_commands": [
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if_absent": [],
  "not_validated_if_present": []
}