{
  "plugin_id": 121479,
  "finding_name": "web.config File Information Disclosure",
  "service": "banner",
  "port_logic": "use_scan_port",
  "command_template": "curl -k -s --max-time 20 http://{host}:{port}/web.config",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I http://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "<?xml",
    "configuration>",
    "<system.web>",
    "<appsettings>",
    "connectionstrings",
    "system.webserver",
    "<configuration"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [
    "404 not found",
    "403 forbidden",
    "not found",
    "access denied"
  ],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "could not connect",
    "host seems down",
    "failed to resolve"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "could not connect": "port_closed",
    "host seems down": "host_down",
    "failed to resolve": "host_down"
  },
  "version_rule": {},
  "analyst_note": "Version detection via HTTP banner/header.",
  "references": [],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16",
  "fallback_commands": [
    "curl -k -s --max-time 20 https://{host}:{port}/web.config"
  ]
}