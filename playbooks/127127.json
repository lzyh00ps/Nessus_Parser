{
  "plugin_id": 127127,
  "finding_name": "Ansible Tower 3.3.x < 3.3.6 / 3.4.x < 3.4.4 / 3.5.x < 3.5.1 CRLF Vulnerability",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/api/v2/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "401 unauthorized"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "401 unauthorized": "auth_required"
  },
  "version_rule": {
    "product_terms": [
      "ansible",
      "ansible tower",
      "awx"
    ],
    "version_patterns": [
      "ansible[/ ]([0-9]+\\.[0-9]+\\.[0-9]+)",
      "Ansible[/ ]([0-9]+\\.[0-9]+\\.[0-9]+)",
      "tower[/ ]([0-9]+\\.[0-9]+\\.[0-9]+)",
      "AWX[/ ]([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "3.3.6",
    "fixed_version": "3.3.6"
  },
  "analyst_note": "Ansible Tower/AWX version via /api/v2/ endpoint. Fixed: 3.3.6. CVEs: CVE-2019-9740.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2019-9740",
    "http://www.nessus.org/u?b98ff3bb",
    "http://www.nessus.org/u?a90b57b1",
