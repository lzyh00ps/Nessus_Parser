{
  "plugin_id": 146531,
  "finding_name": "Webmin <= 1.941 Multiple Vulnerabilities",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I http://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "webmin",
      "miniserv"
    ],
    "version_patterns": [
      "MiniServ/([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)",
      "miniserv/([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)",
      "Webmin/([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)",
      "webmin/([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)",
      "http-server-header: miniserv/([0-9]+\\.[0-9]+)"
    ]
  },
  "analyst_note": "Webmin exposes its version via the Server: MiniServ/X.Y HTTP response header. CVEs: CVE-2020-8820, CVE-2020-8821, CVE-2020-12670.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2020-8820",
    "http://www.webmin.com/changes.html",
    "http://www.webmin.com/security.html"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}