{
  "plugin_id": 88380,
  "finding_name": "Oracle MySQL 5.5.x < 5.5.47 Multiple Vulnerabilities (January 2016 CPU)",
  "service": "banner",
  "port_logic": "any",
  "command_template": "nmap -Pn -sV -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "nmap -Pn --script mysql-info -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [
    "MariaDB",
    "Percona"
  ],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "mysql"
    ],
    "version_patterns": [
      "MySQL[^0-9]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "^([0-9]+\\.[0-9]+\\.[0-9]+)-MySQL",
      "mysql ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-mysql",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-log"
    ],
    "affected_lt": "5.5.47",
    "fixed_version": "5.5.47"
  },
  "analyst_note": "Oracle MySQL 5.5.x before 5.5.47 \u2014 January 2016 CPU. Multiple vulnerabilities in MySQL Server components. Fixed: 5.5.47.",
  "references": [
    "https://www.oracle.com/security-alerts/cpujan2016.html",
    "https://nvd.nist.gov/vuln/detail/CVE-2016-0597"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}