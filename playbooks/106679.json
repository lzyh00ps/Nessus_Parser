{
  "plugin_id": 106679,
  "finding_name": "ISC BIND Zone Data Denial of Service",
  "service": "dns",
  "port_logic": "any",
  "command_template": "nmap -Pn --script dns-nsid -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "nmap -Pn -sV --version-light -p {port} {host}",
    "nmap -Pn -sU --script dns-nsid -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "timed out",
    "connection refused",
    "no route to host",
    "network is unreachable",
    "connection timed out"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "bind",
      "named"
    ],
    "version_patterns": [
      "BIND ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "bind ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "dns-nsid: bind.version: ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "ISC BIND[/ ]([0-9]+\\.[0-9.]+)"
    ]
  },
  "analyst_note": "ISC BIND version via NSID/DNS version TXT query. CVEs: CVE-2016-6170.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2016-6170",
    "https://kb.isc.org/article/AA-01390"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}