{
  "plugin_id": 46677,
  "finding_name": "HP System Management Homepage < 6.1.0.102 / 6.1.0-103 Multiple Vulnerabilities",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/xmldata?item=All",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I https://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "ilo",
      "hp ilo",
      "hp system management"
    ],
    "version_patterns": [
      "iLO[^0-9]*([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)",
      "ilo[^0-9]*([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)",
      "HP iLO[/ ]([0-9]+)",
      "<PN>.*iLO.*</PN>.*<FWRI>([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)</FWRI>"
    ],
    "affected_lt": "6.1.0.102",
    "fixed_version": "6.1.0.102"
  },
  "analyst_note": "HP iLO version via /xmldata?item=All XML endpoint. Fixed: 6.1.0.102. CVEs: CVE-2009-3555.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2009-3555",
    "https://seclists.org/bugtraq/2010/May/139",
    "http://www.nessus.org/u?4e8707ba"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}