{
  "plugin_id": 148367,
  "finding_name": "Python Unsupported Version Detection",
  "service": "banner",
  "port_logic": "use_scan_port",
  "command_template": "curl -k -s -I --max-time 15 http://{host}:{port}/",
  "timeout_seconds": 20,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {},
  "fallback_commands": [
    "curl -k -s -I --max-time 15 https://{host}:{port}/",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "version_rule": {
    "product_terms": [
      "python",
      "installed version"
    ],
    "version_patterns": [
      "installed version\\s*:\\s*([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)",
      "python/([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)",
      "x-powered-by: php.*python/([0-9]+\\.[0-9]+)",
      "python\\s+([0-9]+\\.[0-9]+(?:\\.[0-9]+)?)"
    ],
    "affected_lt": "3.9.0"
  },
  "validated_if": [],
  "validated_if_absent": [],
  "not_validated_if": [],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "could not connect",
    "host seems down",
    "could not resolve"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "host seems down": "host_down",
    "could not resolve": "host_down"
  },
  "references": [],
  "reviewed_by": null,
  "last_verified": null
}