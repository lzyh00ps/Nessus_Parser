{
  "plugin_id": 79721,
  "finding_name": "Splunk Enterprise 5.0.x < 5.0.11 Multiple Vulnerabilities (POODLE)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/services/server/info?output_mode=json",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 http://{host}:{port}/services/server/info?output_mode=json",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "401 unauthorized",
    "403 forbidden"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "401 unauthorized": "auth_required",
    "403 forbidden": "auth_required"
  },
  "version_rule": {
    "product_terms": [
      "splunk"
    ],
    "version_patterns": [
      "\"version\":\"([0-9]+\\.[0-9]+\\.[0-9]+)\"",
      "Splunk[/ ]([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "http-server-header: splunk[/ ]([0-9]+\\.[0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "5.0.11",
    "fixed_version": "5.0.11"
  },
  "analyst_note": "Splunk version available via REST API at /services/server/info (port 8089). Fixed: 5.0.11. CVEs: CVE-2014-3566, CVE-2014-3567.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2014-3566",
    "https://www.splunk.com/view/SP-CAAANST",
