{
  "plugin_id": 111603,
  "finding_name": "Jenkins < 2.121.2 / 2.133 Multiple Vulnerabilities",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 -I https://{host}:{port}/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 -I http://{host}:{port}/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "jenkins"
    ],
    "version_patterns": [
      "X-Jenkins: ([0-9]+\\.[0-9.]+)",
      "Hudson-Version: ([0-9]+\\.[0-9.]+)",
      "Jenkins/([0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "2.121.2",
    "fixed_version": "2.121.2 (LTS) / 2.133 (weekly)"
  },
  "analyst_note": "Jenkins exposes its version in the X-Jenkins HTTP response header. Multiple vulnerabilities including CSRF, XSS, path traversal, and sandbox escapes. Jenkins on port 8080 (default) often internet-exposed. If X-Jenkins is present, version comparison is reliable. Unauthenticated access to /script console is a critical indicator \u2014 check /login for existence. Fixed: LTS 2.121.2, weekly 2.133.",
  "references": [
    "https://www.jenkins.io/security/advisory/2018-06-25/",
    "https://nvd.nist.gov/vuln/detail/CVE-2018-1000600"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}