{
  "plugin_id": 99519,
  "finding_name": "MySQL Cluster 7.4.x < 7.4.15 DD Subcomponent Arbitrary Data Manipulation (April 2017 CPU)",
  "service": "banner",
  "port_logic": "any",
  "command_template": "nmap -Pn -sV -p {port} {host}",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "nmap -Pn --script mysql-info -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [],
  "validated_if_absent_json": [],
  "not_validated_if": [
    "MariaDB",
    "Percona"
  ],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable"
  },
  "version_rule": {
    "product_terms": [
      "mysql"
    ],
    "version_patterns": [
      "MySQL[^0-9]*([0-9]+\\.[0-9]+\\.[0-9]+)",
      "^([0-9]+\\.[0-9]+\\.[0-9]+)-MySQL",
      "mysql ([0-9]+\\.[0-9]+\\.[0-9]+)",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-mysql",
      "([0-9]+\\.[0-9]+\\.[0-9]+)-log",
      "mysql-info: ([0-9]+\\.[0-9]+\\.[0-9]+)"
    ],
    "affected_lt": "7.4.15",
    "fixed_version": "7.4.15"
  },
  "analyst_note": "MySQL version is visible in the initial connection banner on port 3306. Fixed: 7.4.15. CVEs: CVE-2017-3304.",
  "references": [
    "https://nvd.nist.gov/vuln/detail/CVE-2017-3304",
