{
  "plugin_id": 31705,
  "finding_name": "SSL Anonymous Cipher Suites Supported",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "sh -c 'out=$(openssl s_client -connect {host}:{port} {openssl_tls_args} -cipher \"aNULL:@SECLEVEL=0\" </dev/null 2>&1); echo \"$out\"; echo \"$out\" | grep -qi \"cipher\\|connected\" && ! echo \"$out\" | grep -qi \"no suitable cipher\\|handshake failure\\|unsupported\" && echo ANON_CIPHER_ACCEPTED || echo ANON_CIPHER_REJECTED'",
  "timeout_seconds": 30,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "validated_if": [
    "anon_cipher_accepted",
    "cipher: adh-",
    "cipher: aecdh-",
    "adh-aes",
    "aecdh-aes",
    "exp-adh",
    "adh-des",
    "adh-rc4",
    "kex: dh anon",
    "kex: ecdh anon"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "anon_cipher_rejected",
    "no ciphers",
    "ssl2",
    "ssl3"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "timed out",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "network is unreachable": "host_down"
  },
  "references": [],
  "reviewed_by": null,
  "last_verified": null,
  "fallback_commands": [
    "nmap -Pn --script ssl-enum-ciphers -p {port} {host}"
  ]
}