{
  "plugin_id": 62312,
  "finding_name": "phpMyAdmin server_sync.php Backdoor Remote Code Execution (PMASA-2012-5 / CVE-2012-5159)",
  "service": "https",
  "port_logic": "any",
  "command_template": "curl -k -s -m 20 https://{host}:{port}/phpmyadmin/",
  "timeout_seconds": 30,
  "allowed_ports_json": "[]",
  "blocked_ports_json": "[]",
  "fallback_commands_json": [
    "curl -k -s -m 20 http://{host}:{port}/phpmyadmin/",
    "curl -k -s -m 20 http://{host}:{port}/pma/",
    "nmap -Pn --script http-headers,http-generator,http-server-header,http-title -p {port} {host}",
    "nmap -Pn -sV --version-light -p {port} {host}"
  ],
  "validated_if": [
    "phpMyAdmin"
  ],
  "validated_if_absent_json": [],
  "not_validated_if": [],
  "not_validated_if_present_json": [],
  "inconclusive_if": [
    "failed to resolve",
    "0 hosts up",
    "host seems down",
    "timed out",
    "connection refused",
    "no route to host",
    "could not connect",
    "network is unreachable",
    "ssl handshake",
    "404 Not Found"
  ],
  "failure_reason_map": {
    "failed to resolve": "dns_failure",
    "0 hosts up": "host_down",
    "host seems down": "host_down",
    "timed out": "port_filtered",
    "connection refused": "port_closed",
    "no route to host": "host_unreachable",
    "network is unreachable": "host_unreachable",
    "404 Not Found": "endpoint_not_found"
  },
  "version_rule": {
    "product_terms": [
      "phpmyadmin"
    ],
    "version_patterns": [
      "phpMyAdmin ([0-9]+\\.[0-9]+\\.[0-9.]+)",
      "pma_version[^>]*>([0-9]+\\.[0-9]+\\.[0-9.]+)"
    ],
    "affected_lt": "3.5.2.2",
    "fixed_version": "3.5.2.2"
  },
  "analyst_note": "PMASA-2012-5: SourceForge mirror of phpMyAdmin 3.5.2.1 was compromised and contained a backdoor in server_sync.php allowing unauthenticated RCE. This is a supply chain compromise. If phpMyAdmin is detected, verify the installation was downloaded from the official phpMyAdmin.net site and check for the presence of server_sync.php. Fixed: download from official source; upgrade to 3.5.2.2+.",
  "references": [
    "https://www.phpmyadmin.net/security/PMASA-2012-5/",
    "https://nvd.nist.gov/vuln/detail/CVE-2012-5159",
    "https://www.exploit-db.com/exploits/21516"
  ],
  "reviewed_by": "analyst",
