{
  "plugin_id": 10863,
  "finding_name": "SSL Certificate Information",
  "service": "tls",
  "port_logic": "use_scan_port",
  "command_template": "sslscan --no-colour --show-certificate {sslscan_starttls_args} --sni-name={host} {host}:{port}",
  "timeout_seconds": 45,
  "allowed_ports": [],
  "blocked_ports": [],
  "starttls_protocol_map": {
    "21": "ftp",
    "25": "smtp",
    "110": "pop3",
    "143": "imap",
    "389": "ldap",
    "5222": "xmpp",
    "5269": "xmpp-server",
    "5432": "postgres",
    "587": "smtp"
  },
  "validated_if": [
    "subject:",
    "issuer:"
  ],
  "validated_if_absent": [],
  "not_validated_if": [
    "could not read certificate"
  ],
  "not_validated_if_present": [],
  "inconclusive_if": [
    "connection refused",
    "connection timed out",
    "failed to resolve",
    "timed out",
    "no route to host",
    "network is unreachable"
  ],
  "failure_reason_map": {
    "connection refused": "port_closed",
    "connection timed out": "port_filtered",
    "failed to resolve": "host_down",
    "timed out": "port_filtered",
    "no route to host": "host_down",
    "network is unreachable": "host_down"
  },
  "references": [
    "https://github.com/rbsec/sslscan"
  ],
  "reviewed_by": "analyst",
  "last_verified": "2026-03-16"
}